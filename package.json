{
  "name": "idemkit-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "idemkit — a TypeScript-first, storage-agnostic idempotency toolkit for Node.js APIs and JS/React clients",
  "type": "module",
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r --filter \"./packages/*\" run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@biomejs/biome"]
  }
}
