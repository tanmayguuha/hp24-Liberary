{
  "name": "hp24-idemkit-next",
  "version": "0.1.0",
  "description": "Next.js idempotency wrappers for App Router route handlers and Pages API routes, powered by hp24-idemkit-core.",
  "keywords": ["idempotency", "next", "nextjs", "app-router", "route-handler", "idempotency-key"],
  "license": "MIT",
  "author": "Harsh Patidar",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist", "README.md"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hp24-idemkit-core": "workspace:^"
  },
  "peerDependencies": {
    "next": ">=13.4.0"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true }
  },
  "devDependencies": {
    "next": "^15.0.0"
  },
  "publishConfig": { "access": "public" }
}
