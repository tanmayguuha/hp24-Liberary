{
  "name": "@idemkit/client",
  "version": "0.1.0",
  "description": "Universal (browser + Node) idempotent fetch wrapper: generates and persists an Idempotency-Key per logical request and safely retries with backoff. Zero dependencies.",
  "keywords": ["idempotency", "fetch", "retry", "idempotency-key", "client", "browser"],
  "license": "MIT",
  "author": "Kapil",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist", "README.md"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": { "access": "public", "provenance": true }
}
