{
  "name": "@idemkit/core",
  "version": "0.1.0",
  "description": "Framework-agnostic idempotency engine: storage interface, in-memory store, body fingerprinting and concurrency-safe lock-before-execute. Zero runtime dependencies.",
  "keywords": [
    "idempotency",
    "idempotency-key",
    "middleware",
    "retry",
    "deduplication",
    "exactly-once",
    "payments",
    "typescript"
  ],
  "license": "MIT",
  "author": "Kapil",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./node": {
      "import": {
        "types": "./dist/node.d.ts",
        "default": "./dist/node.js"
      },
      "require": {
        "types": "./dist/node.d.cts",
        "default": "./dist/node.cjs"
      }
    }
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
