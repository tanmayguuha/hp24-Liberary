{
  "name": "@hp24/idemkit-react",
  "version": "0.1.0",
  "description": "React hooks for idempotent mutations: a useMutation-style hook that safely retries with a stable Idempotency-Key and prevents double-submits.",
  "keywords": ["idempotency", "react", "hook", "mutation", "idempotency-key", "fetch"],
  "license": "MIT",
  "author": "Harsh Patidar",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist", "README.md"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hp24/idemkit-client": "workspace:^"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "happy-dom": "^15.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": { "access": "public" }
}
