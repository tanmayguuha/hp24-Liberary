{
  "name": "hp24-ui",
  "version": "0.3.1",
  "description": "A zero-config, prop-driven Dropdown for React — single/multi-select, searchable, accessible. No CSS import, no Tailwind setup; works in React, Next.js, and any bundler.",
  "keywords": [
    "react",
    "dropdown",
    "select",
    "multi-select",
    "combobox",
    "ui",
    "typescript",
    "nextjs"
  ],
  "license": "MIT",
  "author": "Harsh Patidar",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "playground": "vite"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^15.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
